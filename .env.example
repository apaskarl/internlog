# Copy to `.env` (or `.env.local`) and fill in values. Those files are gitignored.

# Required: random string (e.g. `openssl rand -hex 32`)
AUTH_SECRET=

# Required: only this email may sign in
AUTH_ALLOWED_EMAIL=

# Required: base64 of bcrypt hash — Next.js corrupts raw `$2a$…` in .env. Generate:
#   node scripts/hash-password.cjs "your-password"
AUTH_PASSWORD_HASH_B64=

# Optional: public URL of the app (needed in production for callbacks)
AUTH_URL=http://localhost:3000

# SQLite file for Drizzle (internship data later). Created on first use.
DATABASE_URL=file:./data/internlog.db
